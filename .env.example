# ============================================================
# Environment Variables — Template
# ============================================================
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local — it contains secrets!
# ============================================================

# ── Resend (Email Service) ──
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev
CONTACT_EMAIL=georgiouemm@gmail.com

# ── Firebase Realtime Database ──
FIREBASE_DB_URL=https://your-project-id-default-rtdb.firebaseio.com

# ── Cloudinary (Image CDN) ──
CLOUDINARY_CLOUD_NAME=your-cloud-name

# ── CORS ──
ALLOWED_ORIGIN=https://your-domain.vercel.app

# ── Vercel (used by GitHub Actions — set these as GitHub Secrets) ──
# VERCEL_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
# VERCEL_ORG_ID=team_xxxxxxxxxxxxxxxxxxxxxxxx
# VERCEL_PROJECT_ID=prj_xxxxxxxxxxxxxxxxxxxxxxxx
